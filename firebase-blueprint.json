{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A retail garment product offered in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the product" },
        "name": { "type": "string", "description": "Display name of the product" },
        "brand": { "type": "string", "description": "Brand of the product" },
        "category": { "type": "string", "description": "Main category of the garment" },
        "subCategory": { "type": "string", "description": "Detailed sub-classification of the garment" },
        "price": { "type": "number", "description": "Original price in INR" },
        "offerPrice": { "type": "number", "description": "Special offered price in INR" },
        "images": { "type": "array", "description": "List of product image URLs" },
        "sizes": { "type": "array", "description": "List of available sizes" },
        "colors": { "type": "array", "description": "List of available colors" },
        "ratings": { "type": "number", "description": "Average user rating" },
        "reviewCount": { "type": "number", "description": "Total number of reviews received" },
        "description": { "type": "string", "description": "Detailed text description of the product" },
        "specifications": { "type": "object", "description": "Technical specifications map" },
        "stock": { "type": "number", "description": "Current inventory stock level" },
        "isTrending": { "type": "boolean" },
        "isBestSeller": { "type": "boolean" },
        "isNewArrival": { "type": "boolean" },
        "isTodayDeal": { "type": "boolean" },
        "isSummerCollection": { "type": "boolean" },
        "isFormalWear": { "type": "boolean" },
        "isCasualWear": { "type": "boolean" },
        "isFestivalCollection": { "type": "boolean" }
      },
      "required": ["id", "name", "brand", "category", "price", "offerPrice", "stock"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A promotional discount code",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "Unique promotional code string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"], "description": "Percentage or fixed amount discount" },
        "value": { "type": "number", "description": "Discount value (percentage rate or flat INR)" },
        "minPurchase": { "type": "number", "description": "Minimum order total in INR to apply the coupon" },
        "isActive": { "type": "boolean", "description": "Whether the coupon can currently be applied" },
        "description": { "type": "string", "description": "Detailed explanation of the coupon deal" }
      },
      "required": ["code", "discountType", "value", "minPurchase", "isActive"]
    },
    "Order": {
      "title": "Order",
      "description": "A placed order awaiting merchant verification",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Auto-generated order ID" },
        "orderNumber": { "type": "string", "description": "Human-readable order sequence number" },
        "customerId": { "type": "string", "description": "Customer identifier" },
        "customerName": { "type": "string", "description": "Name of the ordering customer" },
        "customerEmail": { "type": "string", "description": "Email of the ordering customer" },
        "customerPhone": { "type": "string", "description": "Phone number of the ordering customer" },
        "shippingAddress": { "type": "object", "description": "Shipping destination address details" },
        "items": { "type": "array", "description": "List of ordered cart items" },
        "totalAmount": { "type": "number", "description": "Final price paid in INR" },
        "discountAmount": { "type": "number", "description": "Discount applied from any coupon in INR" },
        "couponCode": { "type": "string" },
        "paymentScreenshot": { "type": "string", "description": "Base64 or image URL reference of payment confirmation" },
        "status": {
          "type": "string",
          "enum": ["Payment Verification Pending", "Confirmed", "Packed", "Shipped", "Delivered", "Cancelled"]
        },
        "createdAt": { "type": "string", "description": "Creation timestamp" }
      },
      "required": ["id", "orderNumber", "customerName", "customerEmail", "customerPhone", "shippingAddress", "items", "totalAmount", "status", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A dynamic store product category",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Dynamic display name of the category" },
        "createdAt": { "type": "string", "description": "Creation timestamp" }
      },
      "required": ["name"]
    },
    "DeliverySettings": {
      "title": "DeliverySettings",
      "description": "Global logistic and delivery fee parameters",
      "type": "object",
      "properties": {
        "expressEnabled": { "type": "boolean" },
        "expressCharge": { "type": "number" },
        "normalCharge": { "type": "number" },
        "freeDeliveryThreshold": { "type": "number" },
        "eligibleLocations": { "type": "array" }
      },
      "required": ["expressEnabled", "expressCharge", "normalCharge", "freeDeliveryThreshold", "eligibleLocations"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Store raw garment and product suppliers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "companyName": { "type": "string" },
        "gstin": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "balance": { "type": "number" },
        "createdDate": { "type": "string" }
      },
      "required": ["id", "name", "companyName", "phone", "balance", "createdDate"]
    },
    "PurchaseRecord": {
      "title": "PurchaseRecord",
      "description": "Inventory replenishment records from suppliers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "billNumber": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "items": { "type": "array" },
        "taxableTotal": { "type": "number" },
        "gstTotal": { "type": "number" },
        "grandTotal": { "type": "number" },
        "paymentMode": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "billNumber", "supplierId", "supplierName", "items", "grandTotal", "paymentMode", "status", "createdAt"]
    },
    "POSSale": {
      "title": "POSSale",
      "description": "In-store cashier transactions with detailed GST calculation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "customerGst": { "type": "string" },
        "items": { "type": "array" },
        "subTotal": { "type": "number" },
        "taxTotal": { "type": "number" },
        "discountAmount": { "type": "number" },
        "couponCode": { "type": "string" },
        "shippingCharge": { "type": "number" },
        "packingCharge": { "type": "number" },
        "roundOff": { "type": "number" },
        "grandTotal": { "type": "number" },
        "paymentMode": { "type": "string" },
        "cashierId": { "type": "string" },
        "cashierName": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "invoiceNumber", "items", "subTotal", "taxTotal", "grandTotal", "paymentMode", "cashierId", "cashierName", "createdAt", "status"]
    },
    "POSCustomer": {
      "title": "POSCustomer",
      "description": "Retail customer database with loyalty points and store credit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "gstin": { "type": "string" },
        "loyaltyPoints": { "type": "number" },
        "walletBalance": { "type": "number" },
        "createdDate": { "type": "string" }
      },
      "required": ["id", "name", "phone", "loyaltyPoints", "walletBalance", "createdDate"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Cashier, manager and store admin staff credentials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "pinCode": { "type": "string" },
        "status": { "type": "string" },
        "createdDate": { "type": "string" }
      },
      "required": ["id", "name", "email", "phone", "role", "pinCode", "status", "createdDate"]
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "description": "Clock-in and clock-out logs for retail staff",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "role": { "type": "string" },
        "date": { "type": "string" },
        "clockIn": { "type": "string" },
        "clockOut": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "employeeId", "employeeName", "role", "date", "clockIn", "status"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "System audits and operations log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "employeeId", "employeeName", "action", "details", "timestamp"]
    },
    "ExpenseRecord": {
      "title": "ExpenseRecord",
      "description": "Retail shop operational expenses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "category", "amount", "description", "date", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store garment products catalog"
    },
    "/coupons/{couponCode}": {
      "schema": "Coupon",
      "description": "Promotional discounts"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase orders and payments"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Store garment categories"
    },
    "/settings/{settingId}": {
      "schema": "DeliverySettings",
      "description": "Store logistics and app configurations"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Garment manufacturers and suppliers"
    },
    "/purchases/{purchaseId}": {
      "schema": "PurchaseRecord",
      "description": "Stock inventory purchase ledger"
    },
    "/pos_sales/{saleId}": {
      "schema": "POSSale",
      "description": "In-store cashier offline bills with Indian GST breakdown"
    },
    "/pos_customers/{customerId}": {
      "schema": "POSCustomer",
      "description": "Retail shop customers loyalty card profile"
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Role-based authorization and permissions"
    },
    "/attendance/{attendanceId}": {
      "schema": "AttendanceRecord",
      "description": "Daily employee attendance card"
    },
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Security logs and system updates"
    },
    "/expenses/{expenseId}": {
      "schema": "ExpenseRecord",
      "description": "Shop operational expenses ledger"
    }
  }
}
