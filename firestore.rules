rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Products Collection
    match /products/{productId} {
      // Anyone can read products to view the catalog.
      // Anyone can write during initial database seeding, product addition/removal, or admin operations.
      allow read, write: if true;
    }

    // Coupons Collection
    match /coupons/{couponCode} {
      // Anyone can read coupons.
      // Anyone can write during initial database seeding or coupon management.
      allow read, write: if true;
    }

    // Orders Collection
    match /orders/{orderId} {
      // Anyone can read orders as the app loads all orders on startup.
      // Anyone can create or update orders during checkout.
      allow read, write: if true;
    }

    // Categories Collection
    match /categories/{categoryId} {
      // Anyone can read categories to view collections in menus/navbars.
      // Anyone can write to seed, create, update, or delete categories.
      allow read, write: if true;
    }

    // Settings Collection
    match /settings/{settingId} {
      // Anyone can read settings for delivery and logistics charges.
      // Anyone can write settings to update or seed them.
      allow read, write: if true;
    }

    // Suppliers Collection
    match /suppliers/{supplierId} {
      allow read, write: if true;
    }

    // Purchases Collection
    match /purchases/{purchaseId} {
      allow read, write: if true;
    }

    // POS Sales Collection
    match /pos_sales/{saleId} {
      allow read, write: if true;
    }

    // POS Customers Collection
    match /pos_customers/{customerId} {
      allow read, write: if true;
    }

    // Employees Collection
    match /employees/{employeeId} {
      allow read, write: if true;
    }

    // Attendance Collection
    match /attendance/{attendanceId} {
      allow read, write: if true;
    }

    // Activity Logs Collection
    match /activity_logs/{logId} {
      allow read, write: if true;
    }

    // Expenses Collection
    match /expenses/{expenseId} {
      allow read, write: if true;
    }
  }
}
